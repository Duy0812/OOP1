package model.entity;

import java.time.LocalDate;
import java.time.LocalDateTime;
import java.util.ArrayList;
import java.util.List;

public class Booking {
	private String bookingId;
	private Customer customer;
	private String hallId;
	private LocalDate eventDate;
	private String shift;
	private String status;
	private LocalDateTime createdAt;
	private List<String> dishList;
	private double totalAmount;
	private double depositAmount;

	public Booking(String bookingId, Customer customer, String hallId, LocalDate eventDate, String shift,
			double totalAmount) {
		this.bookingId = bookingId;
		this.customer = customer;
		this.hallId = hallId;
		this.eventDate = eventDate;
		this.shift = shift;
		this.totalAmount = totalAmount;
		this.status = "PENDING";
		this.createdAt = LocalDateTime.now();
		this.dishList = new ArrayList<>();
		this.depositAmount = 0;
	}

	public void addDish(String dishName) {
		dishList.add(dishName);
	}

	public boolean containsDish(String dishName) {
		return dishList.contains(dishName);
	}

	// Xử lý trừ tiền phạt khi khách chủ động hủy
	public void processCancel() {
		System.out.println(">> [Nghiệp vụ] Phạt 50% tiền cọc do hủy hợp đồng.");
		double refund = this.depositAmount * 0.5;
		this.depositAmount = 0;
		this.status = "CANCELLED";
		System.out.println(">> [Nghiệp vụ] Đã hoàn trả: " + String.format("%,.0f", refund) + " VND cho khách hàng.");
	}

	// Getters & Setters
	public String getBookingId() {
		return bookingId;
	}

	public Customer getCustomer() {
		return customer;
	}

	public String getHallId() {
		return hallId;
	}

	public LocalDate getEventDate() {
		return eventDate;
	}

	public String getShift() {
		return shift;
	}

	public String getStatus() {
		return status;
	}

	public void setStatus(String status) {
		this.status = status;
	}

	public LocalDateTime getCreatedAt() {
		return createdAt;
	}

	public List<String> getDishList() {
		return dishList;
	}

	public double getTotalAmount() {
		return totalAmount;
	}

	public double getDepositAmount() {
		return depositAmount;
	}

	public void setDepositAmount(double depositAmount) {
		this.depositAmount = depositAmount;
	}
}
